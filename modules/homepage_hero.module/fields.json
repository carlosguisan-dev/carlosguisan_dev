        "default": {
          "color": "#FFFFFF",
          "opacity": 100
        }
      },
      {
        "label": "Lime Accents",
        "name": "lime_accent",
        "type": "color",
        "default": {
          "color": "#a3d977",
          "opacity": 100
        }
      },
      {
        "label": "Spacing",
        "name": "spacing",
        "type": "spacing"
      }
    ]
  }
]
