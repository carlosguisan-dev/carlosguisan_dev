[
  {
    "label": "Content",
    "name": "content",
    "type": "group",
    "children": [
      {
        "label": "Image",
        "name": "image",
        "type": "image"
      },
      {
        "label": "Tags",
        "name": "tags",
        "type": "text",
        "occurrence": {
          "min": 0,
          "max": 10,
          "default": 2
        }
      },
      {
        "label": "Title",
        "name": "title",
        "type": "text",
        "default": "Ecosistema Global de Datos"
      },
      {
        "label": "Description",
        "name": "description",
        "type": "richtext",
        "default": "Refactorización completa de la infraestructura de leads para una multinacional de logística, integrando sistemas legacy con HubSpot CMS."
      },
      {
        "label": "Metrics",
        "name": "metrics",
        "type": "group",
        "occurrence": {
          "min": 1,
          "max": 3,
          "default": 2
        },
        "children": [
          {
            "label": "Value",
            "name": "metric_value",
            "type": "text",
            "default": "-80%"
          },
          {
            "label": "Label",
            "name": "metric_label",
            "type": "text",
            "default": "Reducción en trabajo manual"
          }
        ],
        "default": [
          { "metric_value": "-80%", "metric_label": "Reducción en trabajo manual" },
          { "metric_value": "+45%", "metric_label": "Mejora en velocidad LCP" }
        ]
      },
      {
        "label": "Link",
        "name": "link",
        "type": "link",
        "default": {
          "url": {
            "href": "#"
          }
        }
      },
      {
        "label": "Link Text",
        "name": "link_text",
        "type": "text",
        "default": "Leer caso de estudio"
      }
    ]
  },
  {
    "label": "Styles",
    "name": "styles",
    "type": "group",
    "tab": "STYLE",
    "children": [
      {
        "label": "Image Position",
        "name": "image_position",
        "type": "choice",
        "choices": [
          ["left", "Left"],
          ["right", "Right"]
        ],
        "default": "left",
        "display": "radio"
      },
      {
        "label": "Dark Mode Style",
        "name": "dark_mode_style",
        "type": "choice",
        "choices": [
          ["deep", "Deep Dark"],
          ["alt", "Alt Dark"]
        ],
        "default": "alt",
        "display": "radio"
      },
      {
        "label": "Accent Color",
        "name": "accent_color",
        "type": "color",
        "default": {
          "color": "#94F21B"
        }
      }
    ]
  }
]
