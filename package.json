{
  "name": "carlosguisan-theme",
  "version": "1.0.0",
  "description": "HubSpot Theme with Tailwind 4 Integration",
  "scripts": {
    "build": "tailwindcss -i ./tailwind/input.css -o ./css/tailwind-built.css --minify",
    "watch": "tailwindcss -i ./tailwind/input.css -o ./css/tailwind-built.css --watch"
  },
  "devDependencies": {
    "tailwindcss": "latest",
    "@tailwindcss/cli": "latest"
  }
}
